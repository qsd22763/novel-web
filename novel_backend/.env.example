# ===== 生产环境配置模板 =====
# 复制为 .env 并修改实际值

# Django
SECRET_KEY=your-production-secret-key-change-this-min-50-chars
DEBUG=False
ALLOWED_HOSTS=your-domain.com,www.your-domain.com,127.0.0.1

# 数据库 (默认使用 SQLite，如需 MySQL 取消下方注释)
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=novel_db
# DB_USER=novel_user
# DB_PASSWORD=your-db-password
# DB_HOST=127.0.0.1
# DB_PORT=3306

# 邮件配置（可选）
# EMAIL_HOST=smtp.qq.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your@qq.com
# EMAIL_HOST_PASSWORD=your-smtp-password
