# ===== 生产环境配置模板 =====
# 复制为 .env 并修改实际值

# Django
SECRET_KEY=your-production-secret-key-change-this-min-50-chars
DEBUG=False
ALLOWED_HOSTS=your-domain.com,www.your-domain.com,127.0.0.1

# ===== MySQL 数据库 =====
DB_ENGINE=django.db.backends.mysql
DB_NAME=novel_fiction
DB_USER=novel_user
DB_PASSWORD=your-mysql-password
DB_HOST=localhost
DB_PORT=3306

